<Window x:Class="AngryIPScanner.Views.Dialogs.SelectFetchersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Fetchers"
        Width="340" Height="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <DockPanel>
        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="12">
            <Button Content="Select All" Width="80" Click="SelectAll_Click"/>
            <Button Content="Select None" Width="90" Click="SelectNone_Click"
                    Margin="8,0,0,0"/>
            <Button Content="OK" Width="80" Click="OK_Click" IsDefault="True"
                    Margin="16,0,0,0"/>
            <Button Content="Cancel" Width="80" Click="Cancel_Click"
                    IsCancel="True" Margin="8,0,0,0"/>
        </StackPanel>

        <!-- Fetcher list -->
        <ListBox x:Name="FetcherList" Margin="12,12,12,0"
                 BorderThickness="1" BorderBrush="#CCCCCC">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Name}"
                              IsChecked="{Binding IsSelected}"
                              Margin="4,3"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
