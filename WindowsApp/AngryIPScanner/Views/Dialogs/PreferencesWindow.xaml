<Window x:Class="AngryIPScanner.Views.Dialogs.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preferences"
        Width="500" Height="560"
        MinWidth="420" MinHeight="400"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <DockPanel>
        <!-- OK / Cancel -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="12">
            <Button Content="OK" Width="80" Click="OK_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Click="Cancel_Click"
                    IsCancel="True" Margin="8,0,0,0"/>
        </StackPanel>

        <TabControl Margin="12,12,12,0">

            <!-- ═══ Scanning Tab ═══ -->
            <TabItem Header="Scanning">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12">
                    <GroupBox Header="Threads" Margin="0,0,0,8">
                        <StackPanel Margin="8">
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Max threads:" Width="140"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="MaxThreadsBox" Width="80"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="Thread delay (ms):" Width="140"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="ThreadDelayBox" Width="80"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Pinging" Margin="0,0,0,8">
                        <StackPanel Margin="8">
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Method:" Width="140"
                                           VerticalAlignment="Center"/>
                                <ComboBox x:Name="PingerCombo" Width="180">
                                    <ComboBoxItem Content="Combined UDP+TCP" Tag="pinger.combined"/>
                                    <ComboBoxItem Content="ICMP" Tag="pinger.icmp"/>
                                    <ComboBoxItem Content="TCP" Tag="pinger.tcp"/>
                                    <ComboBoxItem Content="UDP" Tag="pinger.udp"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="Ping count:" Width="140"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="PingCountBox" Width="80"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="Ping timeout (ms):" Width="140"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="PingTimeoutBox" Width="80"/>
                            </StackPanel>
                            <CheckBox x:Name="ScanDeadHostsCheck" Content="Scan dead hosts"
                                      Margin="0,6,0,0"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Skipping">
                        <StackPanel Margin="8">
                            <CheckBox x:Name="SkipBroadcastCheck"
                                      Content="Skip broadcast addresses"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ Ports Tab ═══ -->
            <TabItem Header="Ports">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12">
                    <GroupBox Header="Timing" Margin="0,0,0,8">
                        <StackPanel Margin="8">
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Port timeout (ms):" Width="140"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="PortTimeoutBox" Width="80"/>
                            </StackPanel>
                            <CheckBox x:Name="AdaptTimeoutCheck" Content="Adapt port timeout"
                                      Margin="0,6,0,0" Click="AdaptTimeout_Click"/>
                            <StackPanel x:Name="MinTimeoutPanel" Orientation="Horizontal"
                                        Margin="20,4,0,0" Visibility="Collapsed">
                                <TextBlock Text="Min timeout (ms):" Width="120"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="MinPortTimeoutBox" Width="80"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Port Selection">
                        <StackPanel Margin="8">
                            <TextBlock Text="Ports to scan (comma-separated, ranges with dashes):"
                                       Foreground="Gray" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox x:Name="PortStringBox" Height="60"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Add Common Ports" Width="130"
                                        Click="AddCommonPorts_Click"/>
                                <Button Content="Reset to Default" Width="120"
                                        Click="ResetPorts_Click" Margin="8,0,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="UseRequestedPortsCheck"
                                      Content="Add requested ports from file feeder"
                                      Margin="0,8,0,0"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ Display Tab ═══ -->
            <TabItem Header="Display">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12">
                    <GroupBox Header="Labels">
                        <StackPanel Margin="8">
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Not available:" Width="120"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="NotAvailableBox" Width="100"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="Not scanned:" Width="120"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="NotScannedBox" Width="100"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
