<Window x:Class="AngryIPScanner.Views.Dialogs.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Angry IP Scanner"
        Width="340" Height="200"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                Margin="24">
        <TextBlock Text="Angry IP Scanner" FontSize="22" FontWeight="Bold"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Native Windows Edition" FontSize="13" Foreground="Gray"
                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
        <TextBlock Text="Fast cross-platform network scanner" FontSize="12"
                   HorizontalAlignment="Center" Margin="0,16,0,0"/>
        <TextBlock Text="Go core + WPF interface" FontSize="11" Foreground="Gray"
                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
        <Button Content="OK" Width="80" Click="OK_Click"
                HorizontalAlignment="Center" Margin="0,20,0,0" IsDefault="True"/>
    </StackPanel>
</Window>
