<Window x:Class="GoNetworkScanner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:GoNetworkScanner.Views"
        Title="Go Network Scanner"
        Width="960" Height="560"
        MinWidth="640" MinHeight="420"
        Icon="/Resources/app.ico"
        Closing="Window_Closing">

    <Window.Resources>
        <views:ResultTypeToColorConverter x:Key="TypeToColor"/>

        <Style x:Key="MonoCell" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>
        <Style x:Key="Cell" TargetType="TextBlock">
            <Setter Property="Margin" Value="4,0"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- ═══ Menu Bar ═══ -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New Window" Click="NewWindow_Click"
                          InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open IP List..." Click="OpenFile_Click"
                          InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="_Export Results..." Click="Export_Click"
                          InputGestureText="Ctrl+S"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>

            <MenuItem Header="_Edit">
                <MenuItem Header="Copy _IP" Click="CopyIP_Click"
                          InputGestureText="Ctrl+Shift+C"/>
                <MenuItem Header="Copy _All Columns" Click="CopyAll_Click"
                          InputGestureText="Ctrl+Alt+C"/>
                <Separator/>
                <MenuItem Header="_Find..." Click="Find_Click"
                          InputGestureText="Ctrl+F"/>
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem Header="Show _All" Click="FilterAll_Click"/>
                <MenuItem Header="Show A_live Only" Click="FilterAlive_Click"/>
                <MenuItem Header="Show _With Ports Only" Click="FilterWithPorts_Click"/>
            </MenuItem>

            <MenuItem Header="_Scan">
                <MenuItem Header="_Statistics..." Click="Statistics_Click"
                          InputGestureText="Ctrl+T"/>
                <Separator/>
                <MenuItem Header="Sele_ct">
                    <MenuItem Header="Select _Alive" Click="SelectAlive_Click"/>
                    <MenuItem Header="Select _Dead" Click="SelectDead_Click"/>
                    <MenuItem Header="Select With _Ports" Click="SelectWithPorts_Click"/>
                    <Separator/>
                    <MenuItem Header="_Invert Selection" Click="SelectInvert_Click"
                              InputGestureText="Ctrl+I"/>
                </MenuItem>
                <MenuItem Header="Export Selec_tion..." Click="ExportSelection_Click"/>
            </MenuItem>

            <MenuItem Header="F_avorites">
                <MenuItem Header="_Save Current Scan..." Click="SaveFavorite_Click"/>
                <MenuItem Header="_Manage Favorites..." Click="ManageFavorites_Click"/>
            </MenuItem>

            <MenuItem Header="_Go To">
                <MenuItem Header="_Next Alive Host" Click="NextAlive_Click"
                          InputGestureText="Ctrl+Alt+Down"/>
                <MenuItem Header="_Previous Alive Host" Click="PrevAlive_Click"
                          InputGestureText="Ctrl+Alt+Up"/>
            </MenuItem>

            <MenuItem Header="_Tools">
                <MenuItem Header="_Preferences..." Click="Preferences_Click"/>
                <MenuItem Header="Select _Fetchers..." Click="SelectFetchers_Click"/>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="_About Go Network Scanner" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- ═══ Status Bar ═══ -->
        <Border DockPanel.Dock="Bottom" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
                Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText" Grid.Column="0" Text="Ready"
                           VerticalAlignment="Center" Foreground="Gray" FontSize="12"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0">
                    <RadioButton x:Name="FilterAll" Content="All" IsChecked="True"
                                 Click="FilterAll_Click" GroupName="Filter"/>
                    <RadioButton x:Name="FilterAlive" Content="Alive"
                                 Click="FilterAlive_Click" GroupName="Filter" Margin="8,0,0,0"/>
                    <RadioButton x:Name="FilterWithPorts" Content="With Ports"
                                 Click="FilterWithPorts_Click" GroupName="Filter" Margin="8,0,0,0"/>
                </StackPanel>

                <TextBlock x:Name="ThreadsText" Grid.Column="2"
                           VerticalAlignment="Center" Foreground="Gray" FontSize="12"
                           Margin="8,0" Visibility="Collapsed"/>

                <ProgressBar x:Name="ProgressBar" Grid.Column="3"
                             Width="120" Height="14" Maximum="100"
                             Margin="8,0" Visibility="Collapsed"/>

                <StackPanel Grid.Column="4" Orientation="Horizontal"
                            Margin="8,0" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="LimeGreen"/>
                    <TextBlock x:Name="AliveCount" Text="0" FontSize="12"
                               Foreground="Gray" Margin="3,0,10,0"/>
                    <Ellipse Width="8" Height="8" Fill="DodgerBlue"/>
                    <TextBlock x:Name="WithPortsCount" Text="0" FontSize="12"
                               Foreground="Gray" Margin="3,0,10,0"/>
                    <Ellipse Width="8" Height="8" Fill="IndianRed"/>
                    <TextBlock x:Name="DeadCount" Text="0" FontSize="12"
                               Foreground="Gray" Margin="3,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Main Content ═══ -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ─── Find bar (Ctrl+F) ─── -->
            <Border x:Name="FindBar" Grid.Row="0" Padding="12,6" Background="#FFF9E8"
                    BorderBrush="#E0D090" BorderThickness="0,0,0,1"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔍" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="FindBox" Width="240" VerticalContentAlignment="Center"
                             KeyDown="FindBox_KeyDown"/>
                    <Button Content="Find Next" Click="FindNext_Click" Margin="8,0,0,0"/>
                    <Button Content="Close" Click="FindClose_Click" Margin="4,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- ─── Feeder Area ─── -->
            <Border Grid.Row="1" Padding="12,8" Background="#FAFAFA"
                    BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="ModeCombo" Grid.Column="0" Width="100"
                              Margin="0,0,12,0" SelectionChanged="Mode_Changed"
                              VerticalContentAlignment="Center">
                        <ComboBoxItem Content="IP Range" IsSelected="True"/>
                        <ComboBoxItem Content="CIDR"/>
                    </ComboBox>

                    <StackPanel x:Name="RangePanel" Grid.Column="1"
                                Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBox x:Name="StartIPBox" Width="160" VerticalContentAlignment="Center"
                                 KeyDown="IPBox_KeyDown"/>
                        <TextBlock Text="  to  " VerticalAlignment="Center" Foreground="Gray"/>
                        <TextBox x:Name="EndIPBox" Width="160" VerticalContentAlignment="Center"
                                 KeyDown="IPBox_KeyDown"/>
                    </StackPanel>

                    <StackPanel x:Name="CidrPanel" Grid.Column="1"
                                Orientation="Horizontal" VerticalAlignment="Center"
                                Visibility="Collapsed">
                        <TextBox x:Name="CidrIPBox" Width="160" VerticalContentAlignment="Center"
                                 KeyDown="IPBox_KeyDown"/>
                        <TextBlock Text="  /  " VerticalAlignment="Center" Foreground="Gray"/>
                        <ComboBox x:Name="CidrPrefixCombo" Width="65"
                                  VerticalContentAlignment="Center"
                                  SelectionChanged="CidrPrefix_Changed"/>
                    </StackPanel>

                    <ComboBox x:Name="PingerCombo" Grid.Column="2" Width="130"
                              Margin="0,0,12,0" SelectionChanged="Pinger_Changed"
                              VerticalContentAlignment="Center"
                              ToolTip="Scan type — how hosts are probed for reachability">
                        <ComboBoxItem Content="Combined" Tag="pinger.combined" IsSelected="True"/>
                        <ComboBoxItem Content="ICMP" Tag="pinger.icmp"/>
                        <ComboBoxItem Content="TCP" Tag="pinger.tcp"/>
                        <ComboBoxItem Content="UDP" Tag="pinger.udp"/>
                    </ComboBox>

                    <Button x:Name="StartButton" Grid.Column="3"
                            Content="Start" Width="88" Height="28"
                            Margin="0,0,0,0" Click="StartStop_Click"/>
                </Grid>
            </Border>

            <!-- ─── Results DataGrid ─── -->
            <DataGrid x:Name="ResultsGrid" Grid.Row="2"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#F8F8F8"
                      RowHeaderWidth="0"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      BorderThickness="0"
                      MouseDoubleClick="ResultsGrid_DoubleClick">

                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="IP" Width="155"
                                            SortMemberPath="SortableIP">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4,0">
                                    <Ellipse Width="8" Height="8"
                                             Fill="{Binding TypeString, Converter={StaticResource TypeToColor}}"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding IP}" FontFamily="Consolas"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Ping" Width="80"
                                        Binding="{Binding Ping}"
                                        ElementStyle="{StaticResource MonoCell}"/>

                    <DataGridTextColumn Header="TTL" Width="55"
                                        Binding="{Binding TTL}"
                                        ElementStyle="{StaticResource MonoCell}"/>

                    <DataGridTextColumn Header="Hostname" Width="190"
                                        Binding="{Binding Hostname}"
                                        ElementStyle="{StaticResource Cell}"/>

                    <DataGridTextColumn Header="Ports" Width="220"
                                        Binding="{Binding Ports}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MonoCell}">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="ToolTip" Value="{Binding Ports}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Filtered" Width="140"
                                        Binding="{Binding FilteredPorts}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MonoCell}">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="ToolTip">
                                    <Setter.Value>
                                        <MultiBinding StringFormat="{}Timed out — likely firewalled or a slow service: {0}">
                                            <Binding Path="FilteredPorts"/>
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="MAC Address" Width="145"
                                        Binding="{Binding MACAddress}"
                                        ElementStyle="{StaticResource MonoCell}"/>

                    <DataGridTextColumn Header="MAC Vendor" Width="145"
                                        Binding="{Binding MACVendor}"
                                        ElementStyle="{StaticResource Cell}"/>

                    <DataGridTextColumn Header="Web detect" Width="145"
                                        Binding="{Binding WebDetect}"
                                        ElementStyle="{StaticResource Cell}"/>
                </DataGrid.Columns>

                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Show Details..." Click="ShowDetails_Click"/>
                        <Separator/>
                        <MenuItem Header="Copy IP" Click="CopyIP_Click"
                                  InputGestureText="Ctrl+Shift+C"/>
                        <MenuItem Header="Copy All Columns" Click="CopyAll_Click"
                                  InputGestureText="Ctrl+Alt+C"/>
                        <Separator/>
                        <MenuItem Header="Open">
                            <MenuItem Header="Web Browser" Click="OpenBrowser_Click"/>
                            <MenuItem Header="SSH" Click="OpenSSH_Click"/>
                            <MenuItem Header="Ping" Click="OpenPing_Click"/>
                            <MenuItem Header="Traceroute" Click="OpenTracert_Click"/>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Header="Rescan" Click="RescanSelected_Click"/>
                        <MenuItem Header="Delete" Click="DeleteSelected_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>
        </Grid>
    </DockPanel>
</Window>
