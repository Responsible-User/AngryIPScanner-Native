<Window x:Class="GoNetworkScanner.Views.Dialogs.SaveFavoriteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save Favorite"
        Width="360" Height="210"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="20">
        <TextBlock Text="Save Favorite" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <TextBlock Text="Name:" Margin="0,0,0,2"/>
        <TextBox x:Name="NameBox" Margin="0,0,0,8" TextChanged="Name_Changed"/>

        <TextBlock x:Name="RangeText" Foreground="Gray" FontSize="11" Margin="0,0,0,4"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Width="80" Click="Cancel_Click" IsCancel="True"/>
            <Button x:Name="SaveButton" Content="Save" Width="80"
                    Click="Save_Click" IsDefault="True" IsEnabled="False" Margin="8,0,0,0"/>
        </StackPanel>
    </StackPanel>
</Window>
