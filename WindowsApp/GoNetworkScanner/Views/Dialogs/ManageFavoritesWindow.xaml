<Window x:Class="GoNetworkScanner.Views.Dialogs.ManageFavoritesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Favorites"
        Width="460" Height="380"
        MinWidth="380" MinHeight="280"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Done" Width="80" Click="Done_Click"
                    IsDefault="True" IsCancel="True"/>
        </StackPanel>

        <TextBlock DockPanel.Dock="Top" Text="Favorites"
                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <TextBlock x:Name="EmptyText" DockPanel.Dock="Top"
                   Text="No saved favorites" Foreground="Gray"
                   HorizontalAlignment="Center" Margin="0,40,0,0"
                   Visibility="Collapsed"/>

        <ListBox x:Name="FavoritesList" BorderBrush="#CCCCCC" BorderThickness="1">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Name}" FontWeight="Medium"/>
                            <TextBlock Text="{Binding FeederArgs}"
                                       Foreground="Gray" FontSize="11"/>
                        </StackPanel>

                        <Button Grid.Column="1" Content="Load" Width="60"
                                Click="Load_Click" Tag="{Binding}"
                                Margin="0,0,8,0"/>
                        <Button Grid.Column="2" Content="Delete" Width="70"
                                Click="Delete_Click" Tag="{Binding}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
