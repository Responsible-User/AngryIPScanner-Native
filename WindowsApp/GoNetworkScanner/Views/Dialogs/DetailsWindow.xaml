<Window x:Class="GoNetworkScanner.Views.Dialogs.DetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Details"
        Width="520" Height="480"
        MinWidth="400" MinHeight="320"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Click="OK_Click" IsDefault="True" IsCancel="True"/>
        </StackPanel>

        <TextBlock DockPanel.Dock="Top" x:Name="HeaderText"
                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <Border DockPanel.Dock="Bottom" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0"
                Padding="0,10,0,0" Margin="0,8,0,0">
            <StackPanel>
                <TextBlock Text="Comment" FontSize="11" Foreground="Gray" Margin="0,0,0,4"/>
                <TextBox x:Name="CommentBox" TextChanged="Comment_Changed"
                         Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="DetailsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Label}"
                                       HorizontalAlignment="Right" Margin="0,0,8,0"
                                       Foreground="Gray" FontWeight="Medium"/>
                            <TextBlock Grid.Column="1" Text="{Binding Value}"
                                       TextWrapping="Wrap" FontFamily="Consolas"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
